---
const messages = [
  "experience the greatest website to ever exist",
  "web dev is way too hard",
  "help",
  '"if you wait until the last minute, it only takes a minute to do"',
  "according to all known laws of aviation...",
  "you got games on your phone?",
  "you can't just say perchance",
  "ai can't take my job because I don't have one",
  "how strange it is to be anything at all...",
];
---

<button
  id="greeting"
  data-messages={messages}
  class="hidden text-gray-500 italic lg:inline"
  >{"// " + messages[Math.floor(Math.random() * messages.length)]}</button
>

<script>
  let index = 0;
  const button = document.getElementById("greeting")!;
  const messages = button.dataset.messages!.split(",");

  const randIndex = () => {
    return Math.floor(Math.random() * messages.length);
  };

  const updateMessage = () => {
    let newIndex;
    do {
      newIndex = randIndex();
    } while (newIndex == index);

    button.innerText = "// " + messages[newIndex]!;
  };

  // updateMessage();
  button.addEventListener("click", updateMessage);
</script>
